# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# DeepSeek API key — get from https://platform.deepseek.com
DEEPSEEK_KEY=sk-your-deepseek-api-key-here

# ── Optional: Notion logging ──────────────────────────────────────────────────
# Create a Notion integration at https://www.notion.so/my-integrations
# Then share your Team Directory page with the integration
NOTION_API_KEY=secret_your-notion-integration-token
NOTION_PAGE_ID=your-team-directory-page-id

# ── Optional: Kaggle competitions ─────────────────────────────────────────────
# Download kaggle.json from https://www.kaggle.com/settings -> API -> Create New Token
# Place kaggle.json in this project folder, then set:
KAGGLE_CONFIG_DIR=E:\AgentCompany\AgentCompany
KAGGLE_USERNAME=your_kaggle_username
